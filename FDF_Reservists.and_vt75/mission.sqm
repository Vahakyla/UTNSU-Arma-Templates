unClearServer = {" \n "    params [[""_table"", objNull]];" \n "    if (!isServer || {isNull _table}) exitWith {};" \n "    [_table] call PGS_fnc_shotgunClearPrivatePeeksServer;" \n "    _table setVariable [""PGS_ShotgunActive"", false, true];" \n "    _table setVariable [""PGS_ShotgunFinished"", false, true];" \n "    _table setVariable [""PGS_ShotgunGameId"", """", true];" \n "    _table setVariable [""PGS_ShotgunPlayers"", [], true];" \n "    _table setVariable [""PGS_ShotgunPlayerNames"", [], true];" \n "    _table setVariable [""PGS_ShotgunSeatIndices"", [], true];" \n "    _table setVariable [""PGS_ShotgunRevision"", 0, true];" \n "    _table setVariable [""PGS_ShotgunChamberServer"", []];" \n "    _table setVariable [""PGS_ShotgunPendingActorServer"", -1];" \n "    _table setVariable [""PGS_ShotgunPendingReloadServer"", false];" \n "    private _empty = [] call PGS_fnc_shotgunCreateEmptySnapshot;" \n "    _table setVariable [""PGS_ShotgunSnapshotServer"", _empty];" \n "    _table setVariable [""PGS_ShotgunSnapshot"", _empty, true];" \n "    [_table] call PGS_fnc_shotgunPublishRevisionServer;" \n "};" \n "" \n "PGS_fnc_shotgunGetNextAliveRole = {" \n "    params [" \n "        [""_after"", -1]," \n "        [""_alive"", []]" \n "    ];" \n "    private _count = count _alive;" \n "    if (_count <= 0) exitWith {-1};" \n "    private _found = -1;" \n "    for ""_offset"" from 1 to _count do {" \n "        private _candidate = (_after + _offset) mod _count;" \n "        if (_found < 0 && {_alive param [_candidate, false]}) then {" \n "            _found = _candidate;" \n "        };" \n "    };" \n "    _found" \n "};" \n "" \n "PGS_fnc_shotgunResolveCuffsServer = {" \n "    params [" \n "        [""_table"", objNull]," \n "        [""_snapshot"", []]," \n "        [""_desired"", -1]" \n "    ];" \n "    private _alive = _snapshot param [4, []];" \n "    private _cuffs = +(_snapshot param [6, []]);" \n "    private _actions = +(_snapshot param [15, []]);" \n "   
 _shoe) - 1));" \n "                _hands set [_role, _hand];" \n "            };" \n "        };" \n "        _dealerHand pushBack (_shoe deleteAt ((count _shoe) - 1));" \n "    };" \n "    for ""_role"" from 0 to (_count - 1) do {" \n "        if (_active param [_role, false]) then {" \n "            private _hand = _hands param [_role, []];" \n "            private _value = [_hand] call PGS_fnc_blackjackHandValue;" \n "            _totals set [_role, _value param [0, 0]];" \n "            if ([_hand] call PGS_fnc_blackjackIsNatural) then {" \n "                _statuses set [_role, ""BLACKJACK""];" \n "                _actions set [_role, ""Natural Blackjack""];" \n "            } else {" \n "                _statuses set [_role, ""PLAYING""];" \n "                _actions set [_role, format [""Playing on %1"", _value param [0, 0]]];" \n "            };" \n "        };" \n "    };" \n "    private _dealerValue = [_dealerHand] call PGS_fnc_blackjackHandValue;" \n "    private _dealerVisible = [_dealerHand param [0, -1], -2];" \n "    _table setVariable [""PGS_BlackjackShoeServer"", _shoe];" \n "    _table setVariable [""PGS_BlackjackDealerHandServer"", _dealerHand];" \n "    _state set [0, ""PLAYER_TURNS""];" \n "    _state set [2, -1];" \n "    _state set [5, _hands];" \n "    _state set [6, _totals];" \n "    _state set [7, _statuses];" \n "    _state set [8, _actions];" \n "    _state set [9, _dealerVisible];" \n "    _state set [10, ([[_dealerHand param [0, -1]]] call PGS_fnc_blackjackHandValue) param [0, 0]];" \n "    _state set [11, false];" \n "    _state set [12, true];" \n "    _state set [13, format [""Cards dealt. Dealer shows %1."", [_dealerHand param [0, -1]] call PGS_fnc_pokerCardName]];" \n "    _state set [16, count _shoe];" \n "    if ([_dealerHand] call PGS_fnc_blackjackIsNatural) exitWith {" \n "        [_table, _state] call PGS_fnc_blackjackSettleRoundServer;" \n "        true" \n "    };" \n "    private _first = [-1, _statuses] call PGS_fnc_
tedTable};" \n "        if (isNull _displayTable || {_displayTable != _currentTable && {!_spectatorValid}}) then {" \n "            _unoDisplay closeDisplay 1;" \n "        };" \n "    };" \n "};" \n "" \n "PGS_fnc_maintainSeatStateLocal = {" \n "    if (!hasInterface) exitWith {};" \n "    private _trackedUnit = missionNamespace getVariable [""PGS_SeatUnitLocal"", objNull];" \n "    private _trackedTable = missionNamespace getVariable [""PGS_SeatTableLocal"", objNull];" \n "    private _trackedIndex = missionNamespace getVariable [""PGS_SeatIndexLocal"", -1];" \n "    private _trackedToken = missionNamespace getVariable [""PGS_SeatTokenLocal"", """"];" \n "" \n "    if (_trackedUnit != player) then {" \n "        if (!isNull _trackedUnit) then {" \n "            [_trackedUnit, _trackedTable, _trackedIndex, false] call PGS_fnc_releaseSeatPoseLocal;" \n "        };" \n "        _trackedUnit = player;" \n "        _trackedTable = objNull;" \n "        _trackedIndex = -1;" \n "        _trackedToken = """";" \n "    };" \n "" \n "    if (isNull player) exitWith {};" \n "    private _table = player getVariable [""PGS_SeatedTable"", objNull];" \n "    private _seatIndex = player getVariable [""PGS_SeatIndex"", -1];" \n "    private _seatToken = player getVariable [""PGS_SeatToken"", """"];" \n "    private _valid = alive player" \n "        && {(lifeState player) != ""INCAPACITATED""}" \n "        && {!isNull _table}" \n "        && {_table getVariable [""PGS_IsPartyTable"", false]}" \n "        && {_seatIndex >= 0}" \n "        && {_seatIndex < PGS_CFG_SEAT_COUNT}" \n "        && {(vehicle player) == player};" \n "" \n "    if (!_valid) then {" \n "        if (!isNull _trackedTable || {_trackedIndex >= 0}) then {" \n "            [" \n "                player," \n "                _trackedTable," \n "                _trackedIndex," \n "                alive player && {(lifeState player) != ""INCAPACITATED""} && {(vehicle player) == player}" \n "            ] call PGS_fnc
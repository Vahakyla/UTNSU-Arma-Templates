call PGS_fnc_getChessPlayerSideLocal;" \n "    private _board = [(_table getVariable [""PGS_ChessBoard"", []])] call PGS_fnc_chessNormalizeBoard;" \n "    private _turn = _table getVariable [""PGS_ChessTurn"", 1];" \n "    private _rights = [(_table getVariable [""PGS_ChessCastlingRights"", []])] call PGS_fnc_chessNormalizeCastlingRights;" \n "    private _enPassant = _table getVariable [""PGS_ChessEnPassant"", -1];" \n "    private _finished = _table getVariable [""PGS_ChessFinished"", false];" \n "    private _winner = _table getVariable [""PGS_ChessWinner"", 0];" \n "    private _revision = _table getVariable [""PGS_ChessRevision"", 0];" \n "    private _lastRevision = _display getVariable [""PGS_ChessLastRevision"", -1];" \n "    private _selected = _display getVariable [""PGS_ChessSelectedFrom"", -1];" \n "    if (_revision != _lastRevision) then {" \n "        _display setVariable [""PGS_ChessMovePending"", false];" \n "        _display setVariable [""PGS_ChessPromotionPending"", []];" \n "        if (_selected >= 0 && {([_board param [_selected, 0]] call PGS_fnc_chessPieceSide) != _side}) then {" \n "            _selected = -1;" \n "        };" \n "        _display setVariable [""PGS_ChessSelectedFrom"", _selected];" \n "        private _checkedKing = -1;" \n "        if (!_finished && {[_board, _turn] call PGS_fnc_chessIsKingInCheck}) then {" \n "            _checkedKing = [_board, _turn] call PGS_fnc_chessFindKing;" \n "        };" \n "        _display setVariable [""PGS_ChessCheckedKing"", _checkedKing];" \n "        _display setVariable [""PGS_ChessLegalCacheRevision"", -1];" \n "        _display setVariable [""PGS_ChessLastRevision"", _revision];" \n "    };" \n "    private _legalMoves = [];" \n "    if (_selected >= 0 && {_turn == _side} && {!_finished}) then {" \n "        private _cacheRevision = _display getVariable [""PGS_ChessLegalCacheRevision"", -1];" \n "        private _cacheSelected = _display getVariable [""PGS_ChessLegalCacheSelected"", -1];" \n "        if (_cacheRevision != _revision || {_cacheSelected != _selected}) then {" \n "            _legalMoves = [_board, _side, _selected, _rights, _enPassant] call PGS_fnc_chessGetLegalMoves;" \n "            _display setVariable [""PGS_ChessLegalCache"", _legalMoves];" \n "            _display setVariable [""PGS_ChessLegalCacheRevision"", _revision];" \n "            _display setVariable [""PGS_ChessLegalCacheSelected"", _selected];" \n "        } else {" \n "            _legalMoves = _display getVariable [""PGS_ChessLegalCache"", []];" \n "        };" \n "    } else {" \n "        _display setVariable [""PGS_ChessLegalCache"", []];" \n "        _display setVariable [""PGS_ChessLegalCacheSelected"", -1];" \n "    };" \n "    private _legalDestinations = [];" \n "    {" \n "        _legalDestinations pushBack (_x param [0, -1]);" \n "    } forEach _legalMoves;" \n "    private _lastMove = _table getVariable [""PGS_ChessLastMove"", []];" \n "    private _lastFrom = _lastMove param [0, -1];" \n "    private _lastTo = _lastMove param [1, -1];" \n "    private _checkedKing = _display getVariable [""PGS_ChessCheckedKing"", -1];" \n "    private _squareControls = _display getVariable [""PGS_ChessSquareControls"", []];" \n "    private _pieceControls = _display getVariable [""PGS_ChessPieceControls"", []];" \n "    private _selectionPulse = 0.5 + (0.5 * sin (diag_tickTime * 120));" \n "    for ""_controlIndex"" from 0 to ((count _squareControls) - 1) do {" \n "        private _control = _squareControls param [_controlIndex, controlNull];" \n "        private _picture = _pieceControls param [_controlIndex, controlNull];" \n "        if (!isNull _control) then {" \n "            private _index = _control getVariable [""PGS_ChessSquareIndex"", -1];" \n "            private _row = floor (_index / 8);" \n "            private _column = _index mod 8;" \n "            private _dark = ((_row + _column) mod 2) == 1;" \n "            private _background = if (_dark) then {[0.13, 0.17, 0.20, 1]} else {[0.76, 0.75, 0.67, 1]};" \n "            if (_index == _lastFrom || {_index == _lastTo}) then {" \n "                _background = [0.22, 0.34, 0.43, 1];" \n "            };" \n "            if (_index == _checkedKing) then {" \n "                _background = [0.72, 0.08, 0.08, 1];" \n "            };" \n "            if (_index == _selected) then {" \n "                _background = [" \n "                    0.78 + (0.06 * _selectionPulse)," \n "                    0.55 + (0.05 * _selectionPulse)," \n "                    0.12 + (0.02 * _selectionPulse)," \n "                    1" \n "                ];" \n "            };" \n "            if (_index in _legalDestinations) then {" \n "                _background = if ((_board param [_index, 0]) == 0) then {" \n "                    [0.16, 0.55, 0.28, 1]" \n "                } else {" \n "                    [0.64, 0.20, 0.16, 1]" \n "                };" \n "            };" \n "            _control ctrlSetBackgroundColor _background;" \n "            private _piece = _board param [_index, 0];" \n "            private _squareName = [_index] call PGS_fnc_chessGetSquareName;" \n "            private _specialText = """";" \n "            {" \n "                if ((_x param [0, -1]) == _index) exitWith {" \n "                    private _special = _x param [1, """"];" \n "                    _specialText = switch (_special) do {" \n "                        case ""CASTLE_K"": {"" - castle king-side""};" \n "                        case ""CASTLE_Q"": {"" - castle queen-side""};" \n "                        case ""EN_PASSANT"": {"" - en passant""};" \n "                        case ""PROMOTION"": {"" - promotion""};" \n "                        default {"" - legal destination""};" \n "                    };" \n "                };" \n "            } forEach _legalMoves;" \n "            _control ctrlSetTooltip (if (_piece == 0) then {" \n "                format [""%1%2"", _squareName, _specialText]" \n "            } else {" \n "                format [" \n "                    ""%1: %2 %3%4""," \n "                    _squareName," \n "                    [[_piece] call PGS_fnc_chessPieceSide] call PGS_fnc_chessSideName," \n "                    [_piece] call PGS_fnc_chessPieceName," \n "                    _specialText" \n "                ]" \n "            });" \n "            _control ctrlCommit 0;" \n "            if (!isNull _picture) then {" \n "                private _renderedPiece = _picture getVariable [""PGS_ChessRenderedPiece"", 99];" \n "                if (_renderedPiece != _piece) then {" \n "                    if (_piece == 0) then {" \n "                        _picture ctrlShow false;" \n "                    } else {" \n "                        _picture ctrlSetText ([_piece] call PGS_fnc_chessGetMarkerTextureLocal);" \n "                        _picture ctrlSetTextColor (if (_piece > 0) then {" \n "                            [0.18, 0.62, 1, 1]" \n "                        } else {" \n "                            [1, 0.18, 0.14, 1]" \n "                        });" \n "                        _picture ctrlShow true;" \n "                    };" \n "                    _picture setVariable [""PGS_ChessRenderedPiece"", _piece];" \n "                    _picture ctrlCommit 0;" \n "                };" \n "            };" \n "        };" \n "    };" \n "" \n "    private _names = _table getVariable [""PGS_ChessPlayerNames"", [""NATO White"", ""CSAT Black""]];" \n "    private _whiteName = _names param [0, ""NATO White""];" \n "    private _blackName = _names param [1, ""CSAT Black""];" \n "    private _whiteLabel = _display getVariable [""PGS_ChessWhiteLabel"", controlNull];" \n "    private _blackLabel = _display getVariable [""PGS_ChessBlackLabel"", controlNull];" \n "    private _turnLabel = _display getVariable [""PGS_ChessTurnLabel"", controlNull];" \n "    private _statusOne = _display getVariable [""PGS_ChessStatusOne"", controlNull];" \n "    private _statusTwo = _display getVariable [""PGS_ChessStatusTwo"", controlNull];" \n "    private _drawButton = _display getVariable [""PGS_ChessDrawButton"", controlNull];" \n "    private _claimButton = _display getVariable [""PGS_ChessClaimButton"", controlNull];" \n "    private _resignButton = _display getVariable [""PGS_ChessResignButton"", controlNull];" \n "    if (!isNull _whiteLabel) then {" \n "        _whiteLabel ctrlSetText format [""NATO WHITE  %1"", _whiteName];" \n "        _whiteLabel ctrlCommit 0;" \n "    };" \n "    if (!isNull _blackLabel) then {" \n "        _blackLabel ctrlSetText format [""CSAT BLACK  %1"", _blackName];" \n "        _blackLabel ctrlCommit 0;" \n "    };" \n "    if (!isNull _turnLabel) then {" \n "        _turnLabel ctrlSetText (if (_finished) then {" \n "            if (_winner == 0) then {""RESULT: DRAW""} else {format [""WINNER: %1"", [_winner] call PGS_fnc_chessSideName]}" \n "        } else {" \n "            format [""TURN: %1"", [_turn] call PGS_fnc_chessSideName]" \n "        });" \n "        _turnLabel ctrlSetTextColor (if (_finished) then {" \n "            [0.98, 0.80, 0.22, 1]" \n "        } else {" \n "            if (_turn > 0) then {[0.22, 0.66, 1, 1]} else {[1, 0.28, 0.22, 1]}" \n "        });" \n "        _turnLabel ctrlCommit 0;" \n "    };" \n "    if (!isNull _statusOne) then {" \n "        _statusOne ctrlSetText (_table getVariable [""PGS_ChessStatus"", ""Chess in progress.""]);" \n "        _statusOne ctrlCommit 0;" \n "    };" \n "    if (!isNull _statusTwo) then {" \n "        private _yourRole = if (_side == 0) then {""Observer""} else {[_side] call PGS_fnc_chessSideName};" \n "        private _claimText = if ((_table getVariable [""PGS_ChessCanClaimThreefold"", false]) || {_table getVariable [""PGS_ChessCanClaimFifty"", false]}) then {" \n "            ""  DRAW CLAIM AVAILABLE""" \n "        } else {" \n "            """"" \n "        };" \n "        _statusTwo ctrlSetText format [" \n "            ""You: %1   Full move %2   Halfmove clock %3%4""," \n "            _yourRole," \n "            _table getVariable [""PGS_ChessFullmoveNumber"", 1]," \n "            _table getVariable [""PGS_ChessHalfmoveClock"", 0]," \n "            _claimText" \n "        ];" \n "        _statusTwo ctrlCommit 0;" \n "    };" \n "    private _offerSide = _table getVariable [""PGS_ChessDrawOfferSide"", 0];" \n "    if (!isNull _drawButton) then {" \n "        _drawButton ctrlShow !_spectating;" \n "        if (_finished) then {" \n "            _drawButton ctrlSetText ""Reset to Lobby"";" \n "            _drawButton ctrlEnable !_spectating;" \n "        } else {" \n "            _drawButton ctrlSetText (if (_offerSide == 0) then {" \n "                ""Offer Draw""" \n "            } else {" \n "                if (_offerSide == _side) then {""Withdraw Draw""} else {""Accept Draw""}" \n "            });" \n "            _drawButton ctrlEnable (_side != 0);" \n "        };" \n "        _drawButton ctrlCommit 0;" \n "    };" \n "    if (!isNull _claimButton) then {" \n "        private _canClaim = !_finished" \n "            && {!_spectating}" \n "            && {_side == _turn}" \n "            && {(_table getVariable [""PGS_ChessCanClaimThreefold"", false]) || {_table getVariable [""PGS_ChessCanClaimFifty"", false]}};" \n "        _claimButton ctrlSetText (if (_canClaim) then {""Claim Draw""} else {""No Draw Claim""});" \n "        _claimButton ctrlEnable _canClaim;" \n "        _claimButton ctrlShow (!_spectating && {!_finished});" \n "        _claimButton ctrlCommit 0;" \n "    };" \n "    if (!isNull _resignButton) then {" \n "        private _armed = diag_tickTime <= (_display getVariable [""PGS_ChessResignArmedUntil"", -1]);" \n "        _resignButton ctrlSetText (if (_armed) then {""Confirm Resign""} else {""Resign""});" \n "        _resignButton ctrlEnable (!_spectating && {!_finished} && {_side != 0});" \n "        _resignButton ctrlShow (!_spectating && {!_finished});" \n "        _resignButton ctrlCommit 0;" \n "    };" \n "    private _promotionPending = _display getVariable [""PGS_ChessPromotionPending"", []];" \n "    private _promotionControls = _display getVariable [""PGS_ChessPromotionControls"", []];" \n "    private _showPromotion = !_spectating && {(count _promotionPending) >= 3} && {!_finished};" \n "    {" \n "        if (!isNull _x) then {" \n "            _x ctrlShow _showPromotion;" \n "        };" \n "    } forEach _promotionControls;" \n "    _display setVariable [""PGS_ChessRefreshing"", false];" \n "};" \n "" \n "PGS_fnc_openChessLocal = {" \n "    disableSerialization;" \n "    params [" \n "        [""_table"", objNull]," \n "        [""_spectating"", false]" \n "    ];" \n "    if (!hasInterface || {isNull player}) exitWith {};" \n "    if (" \n "        isNull _table" \n "        || {!([_table, _spectating] call PGS_fnc_isValidGameViewerLocal)}" \n "        || {([_table] call PGS_fnc_getTableActiveGameId) != ""chess""}" \n "    ) exitWith {" \n "        hintSilent ""No active Chess match is available to this viewer."";" \n "    };" \n "    private _parent = findDisplay 46;" \n "    if (isNull _parent) exitWith {" \n "        hintSilent ""The Chess display is unavailable."";" \n "    };" \n "    private _lobby = uiNamespace getVariable [""PGS_LobbyDisplay"", displayNull];" \n "    if (!isNull _lobby) then {_lobby closeDisplay 1;};" \n "    private _checkers = uiNamespace getVariable [""PGS_CheckersDisplay"", displayNull];" \n "    if (!isNull _checkers) then {_checkers closeDisplay 1;};" \n "    private _shotgun = uiNamespace getVariable [""PGS_ShotgunDisplay"", displayNull];" \n "    if (!isNull _shotgun) then {_shotgun closeDisplay 1;};" \n "    private _rps = uiNamespace getVariable [""PGS_RPSDisplay"", displayNull];" \n "    if (!isNull _rps) then {_rps closeDisplay 1;};" \n "    private _blackjack = uiNamespace getVariable [""PGS_BlackjackDisplay"", displayNull];" \n "    if (!isNull _black
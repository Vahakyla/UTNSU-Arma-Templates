ull];" \n "            if ((typeName _value) == ""OBJECT"") then {" \n "                _result set [_index, _value];" \n "            };" \n "        };" \n "    };" \n "    _result" \n "};" \n "" \n "PGS_fnc_normalizeVotes = {" \n "    params [[""_source"", []]];" \n "    if ((typeName _source) != ""ARRAY"") then {" \n "        _source = [];" \n "    };" \n "    private _result = ["""", """", """", """"];" \n "    private _limit = (count _source) min PGS_CFG_SEAT_COUNT;" \n "    if (_limit > 0) then {" \n "        for ""_index"" from 0 to (_limit - 1) do {" \n "            private _value = _source param [_index, """"];" \n "            if ((typeName _value) == ""STRING"") then {" \n "                _result set [_index, _value];" \n "            };" \n "        };" \n "    };" \n "    _result" \n "};" \n "" \n "PGS_fnc_normalizeReady = {" \n "    params [[""_source"", []]];" \n "    if ((typeName _source) != ""ARRAY"") then {" \n "        _source = [];" \n "    };" \n "    private _result = [false, false, false, false];" \n "    private _limit = (count _source) min PGS_CFG_SEAT_COUNT;" \n "    if (_limit > 0) then {" \n "        for ""_index"" from 0 to (_limit - 1) do {" \n "            private _value = _source param [_index, false];" \n "            if ((typeName _value) == ""BOOL"") then {" \n "                _result set [_index, _value];" \n "            };" \n "        };" \n "    };" \n "    _result" \n "};" \n "" \n "PGS_fnc_normalizeOccupancy = {" \n "    params [[""_source"", []]];" \n "    if ((typeName _source) != ""ARRAY"") then {" \n "        _source = [];" \n "    };" \n "    private _result = [false, false, false, false];" \n "    private _limit = (count _source) min PGS_CFG_SEAT_COUNT;" \n "    if (_limit > 0) then {" \n "        for ""_index"" from 0 to (_limit - 1) do {" \n "            private _value = _source param [_index, false];" \n "            if ((typeName _value) == ""BOOL"") then {" \n "                _result set [_index, _value];" \n "            };" \n "        };" \n "    };" \n "    _result" \n "};" \n "" \n "PGS_fnc_getTableOccupantCount = {" \n "    params [[""_table"", objNull]];" \n "    if (isNull _table) exitWith {0};" \n "    private _count = 0;" \n "    {" \n "        if (!isNull _x) then {" \n "            _count = _count + 1;" \n "        };" \n "    } forEach ([(_table getVariable [""PGS_TableSeats"", []])] call PGS_fnc_normalizeSeats);" \n "    _count" \n "};" \n "" \n "PGS_fnc_getVoteCount = {" \n "    params [" \n "        [""_table"", objNull]," \n "        [""_gameId"", """"]" \n "    ];" \n "    if (isNull _table || {_gameId == """"}) exitWith {0};" \n "    private _seats = [(_table getVariable [""PGS_TableSeats"", []])] call PGS_fnc_normalizeSeats;" \n "    private _votes = [(_table getVariable [""PGS_TableVotes"", []])] call PGS_fnc_normalizeVotes;" \n "    private _count = 0;" \n "    for ""_index"" from 0 to (PGS_CFG_SEAT_COUNT - 1) do {" \n "        if (!isNull (_seats param [_index, objNull]) && {(_votes param [_index, """"]) == _gameId}) then {" \n "            _count = _count + 1;" \n "        };" \n "    };" \n "    _count" \n "};" \n "" \n "PGS_fnc_isGameEligibleAtTable = {" \n "    params [" \n "        [""_table"", objNull]," \n "        [""_gameId"", """"]" \n "    ];" \n "    if (isNull _table) exitWith {false};" \n "    private _game = [_gameId] call PGS_fnc_getGame;" \n "    if ((count _game) < 5) exitWith {false};" \n "    private _players = [_table] call PGS_fnc_getTableOccupantCount;" \n "    _players >= (_game param [3, 2]) && {_players <= (_game param [4, 4])}" \n "};" \n "" \n "PGS_fnc_getSeatIndex = {" \n "    params [" \n "        [""_table"", objNull]," \n "        [""_unit"", objNull]" \n "    ];" \n "    if (isNull _table || {isNull _unit}) exitWith {-1};" \n "    private _seats = [(_table getVariable [""PGS_TableSeats"", []])] call PGS_fnc_normalizeSeats;" \n "    _seats find _unit" \n "};" \n "" \n "PGS_fnc_getUnitKey = {" \n "    params [[""_unit"", objNull]];" \n "    if (isNull _unit) exitWith {""""};" \n "    private _key = getPlayerUID _unit;" \n "    if (_key == """") then {" \n "        _key = format [""NAME_%1"", name _unit];" \n "    };" \n "    if (_key == ""NAME_"") then {" \n "        _key = format [""NET_%1"", netId _unit];" \n "    };" \n "    _key" \n "};" \n "" \n "PGS_fnc_makeToken = {" \n "    params [[""_prefix"", ""PGS""]];" \n "    format [" \n "        ""%1_%2_%3_%4""," \n "        _prefix," \n "        [player] call PGS_fnc_getUnitKey," \n "        floor (diag_tickTime * 1000)," \n "        floor (random 1000000)" \n "    ]" \n "};" \n "" \n "PGS_fnc_collectTaggedClassObjects = {" \n "    params [" \n "        [""_classes"", []]," \n "        [""_tag"", """"]" \n "    ];" \n "    private _found = [];" \n "    {" \n "        if (isClass (configFile >> ""CfgVehicles"" >> _x)) then {" \n "            {" \n "                if (!isNull _x && {_x getVariable [_tag, false]}) then {" \n "                    _found pushBackUnique _x;" \n "                };" \n "            } forEach (allMissionObjects _x);" \n "        };" \n "    } forEach _classes;" \n "    _found" \n "};" \n "" \n "PGS_fnc_enforceInvulnerableLocal = {" \n "    params [[""_object"", objNull]];" \n "    if (isNull _object) exitWith {};" \n "    if (local _object) then {" \n "        _object allowDamage false;" \n "    };" \n "}; " \n " " \n "PGS_fnc_checkersNormalizeBoard = {" \n "    params [[""_source"", []]];" \n "    if ((typeName _source) != ""ARRAY"") then {" \n "        _source = [];" \n "    };" \n "    private _board = [];" \n "    _board resize 64;" \n "    for ""_index"" from 0 to 63 do {" \n "        private _piece = _source param [_index, 0];" \n "        if ((typeName _piece) != ""SCALAR"" || {!(_piece in [-2, -1, 0, 1, 2])}) then {" \n "            _piece = 0;" \n "        };" \n "        _board set [_index, _piece];" \n "    };" \n "    _board" \n "};" \n "" \n "PGS_fnc_checkersCreateBoard = {" \n "    private _board = [];" \n "    _board resize 64;" \n "    for ""_index"" from 0 to 63 do {" \n "        _board set [_index, 0];" \n "    };" \n "    for ""_row"" from 0 to 7 do {" \n "        for ""_column"" from 0 to 7 do {" \n "            if (((_row + _column) mod 2) == 1) then {" \n "                private _index = (_row * 8) + _column;" \n "                if (_row <= 2) then {" \n "                    _board set [_index, -1];" \n "                };" \n "                if (_row >= 5) then {" \n "                    _board set [_index, 1];" \n "                };" \n "            };" \n "        };" \n "    };" \n "    _board" \n "};" \n "" \n "PGS_fnc_checkersPieceSide = {" \n "    params [[""_piece"", 0]];" \n "    if (_piece > 0) exitWith {1};" \n "    if (_piece < 0) exitWith {-1};" \n "    0" \n "};" \n "" \n "PGS_fnc_checkersSideName = {" \n "    params [[""_side"", 0]];" \n "    if (_side > 0) exitWith {""NATO Blue""};" \n "    if (_side < 0) exitWith {""OPFOR Red""};" \n "    ""Neither side""" \n "};" \n "" \n "PGS_fnc_checkersGetDirections = {" \n "    params [[""_piece"", 0]];" \n "    if ((abs _piece) == 2) exitWith {" \n "        [[-1, -1], [-1, 1], [1, -1], [1, 1]]" \n "    };" \n "    if (_piece > 0) exitWith {" \n "        [[-1, -1], [-1, 1]]" \n "    };" \n "    if (_piece < 0) exitWith {" \n "        [[1, -1], [1, 1]]" \n "    };" \n "    []" \n "};" \n "" \n "PGS_fnc_checkersGetCaptureMoves = {" \n "    params [" \n "        [""_source"", []]," \n "        [""_from"", -1]" \n "    ];" \n "    if (_from < 0 || {_from > 63}) exitWith {[]};" \n "    private _board = [_source] call PGS_fnc_checkersNormalizeBoard;" \n "    private _piece = _board param [_from, 0];" \n "    private _side = [_piece] call PGS_fnc_checkersPieceSide;" \n "    if (_side == 0) exitWith {[]};" \n "    private _row = floor (_from / 8);" \n "    private _column = _from mod 8;" \n "    private _moves = [];" \n "    {" \n "        private _rowDirection = _x param [0, 0];" \n "        private _columnDirection = _x param [1, 0];" \n "        private _middleRow = _row + _rowDirection;" \n "        private _middleColumn = _column + _columnDirection;" \n "        private _landingRow = _row + (2 * _rowDirection);" \n "        private _landingColumn = _column + (2 * _columnDirection);" \n "        if (" \n "            _landingRow >= 0 && {_landingRow <= 7}" \n "            && {_landingColumn >= 0} && {_landingColumn <= 7}" \n "            && {_middleRow >= 0} && {_middleRow <= 7}" \n "            && {_middleColumn >= 0} && {_middleColumn <= 7}" \n "        ) then {" \n "            private _middleIndex = (_middleRow * 8) + _middleColumn;" \n "            private _landingIndex = (_landingRow * 8) + _landingColumn;" \n "            private _middlePiece = _board param [_middleIndex, 0];" \n "            if (" \n "                ([_middlePiece] call PGS_fnc_checkersPieceSide) == (-_side)" \n "                && {(_board param [_landingIndex, 0]) == 0}" \n "            ) then {" \n "                _moves pushBack [_landingIndex, _middleIndex];" \n "            };" \n "        };" \n "    } forEach ([_piece] call PGS_fnc_checkersGetDirections);" \n "    _moves" \n "};" \n "" \n "PGS_fnc_checkersGetStepMoves = {" \n "    params [" \n "        [""_source"", []]," \n "        [""_from"", -1]" \n "    ];" \n "    if (_from < 0 || {_from > 63}) exitWith {[]};" \n "    private _board = [_source] call PGS_fnc_checkersNormalizeBoard;" \n "    private _piece = _board param [_from, 0];" \n "    if (_piece == 0) exitWith {[]};" \n "    private _row = floor (_from / 8);" \n "    private _column = _from mod 8;" \n "    private _moves = [];" \n "    {" \n "        private _landingRow = _row + (_x param [0, 0]);" \n "        private _landingColumn = _column + (_x param [1, 0]);" \n "        if (" \n "            _landingRow >= 0 && {_landingRow <= 7}" \n "            && {_landingColumn >= 0} && {_landingColumn <= 7}" \n "        ) then {" \n "            private _la
								init="private _PGS_Runtime = { " \n "private _pgsCompositionHost = if (isNil ""this"") then {objNull} else {this};" \n "private _pgsStoredHost = missionNamespace getVariable [""PGS_CompositionHostObject"", objNull];" \n "if (!isNull _pgsCompositionHost) then {" \n "    missionNamespace setVariable [""PGS_CompositionHostObject"", _pgsCompositionHost];" \n "    if (local _pgsCompositionHost) then {" \n "        _pgsCompositionHost allowDamage false;" \n "    };" \n "    _pgsCompositionHost setVariable [""PGS_CompositionSeed"", true, true];" \n "} else {" \n "    if (isNull _pgsStoredHost) then {" \n "        missionNamespace setVariable [""PGS_CompositionHostObject"", objNull];" \n "    };" \n "};" \n "" \n "PGS_Version = ""1.3.1"";" \n "" \n "private _pgsRuntimeKey = missionNamespace getVariable [""PGS_RuntimeKeyLocal"", []];" \n "private _pgsRuntimeVersion = _pgsRuntimeKey param [0, """"];" \n "private _pgsRuntimeHost = _pgsRuntimeKey param [1, objNull];" \n "private _pgsDuplicateRuntime = (_pgsRuntimeVersion == PGS_Version) && {" \n "    isNull _pgsCompositionHost || {_pgsRuntimeHost == _pgsCompositionHost}" \n "};" \n "if (_pgsDuplicateRuntime) exitWith {};" \n "missionNamespace setVariable [""PGS_RuntimeKeyLocal"", [PGS_Version, _pgsCompositionHost]]; " \n " " \n "PGS_Games = [" \n "    [" \n "        ""shotgun""," \n "        ""Shotgun Roulette""," \n "        [" \n "            ""Read the shell ledger, use items and choose where to aim.""," \n "            ""Last player with lives remaining wins the table.""" \n "        ]," \n "        2," \n "        4," \n "        [" \n "            ""Playable: hidden chamber, self-shots, targeting and six items.""," \n "            ""Three lives each; empty loads preserve lives and carried items.""" \n "        ]" \n "    ]," \n "    [" \n "        ""blackjack""," \n "        ""Blackjack""," \n "        [" \n "            ""Challenge the automated dealer without passing 21.""," \n "            ""Playable alone or with up to three fellow gamblers.""" \n "        ]," \n "        1," \n "        4," \n "        [" \n "            ""Playable: even bets, Hit, Stand, Double and 3:2 Blackjack.""," \n "            ""Dealer stands on soft 17; no splits, insurance or surrender.""" \n "        ]" \n "    ]," \n "    [" \n "        ""poker""," \n "        ""Poker""," \n "        [" \n "            ""Read the table and manage the pot.""," \n "            ""Conceal good hands; bluff responsibly.""" \n "        ]," \n "        2," \n "        4," \n "        [" \n "            ""Playable no-limit Hold'em with blinds, side pots and all-ins.""," \n "            ""Start with 100 chips; survive the table to win.""" \n "        ]" \n "    ]," \n "    [" \n "        ""chess""," \n "        ""Chess""," \n "        [" \n "            ""A two-player strategy duel.""," \n "            ""Plan ahead while Zeus plans the mission.""" \n "        ]," \n "        2," \n "        2," \n "        [" \n "            ""Playable: check, castling, en passant and promotion.""," \n "            ""Marker-icon armies turn the table into a command board.""" \n "        ]" \n "    ]," \n "    [" \n "        ""checkers""," \n "        ""Checkers""," \n "        [" \n "            ""A quick duel of diagonals and captures.""," \n "            ""Reach the far side and earn a king.""" \n "        ]," \n "        2," \n "        2," \n "        [" \n "            ""Playable: compulsory captures and chained jumps.""," \n "            ""Blue moves first; reach the far rank to earn a king.""" \n "        ]" \n "    ]," \n "    [" \n "        ""rps""," \n "        ""Rock Paper Scissors""," \n "        [" \n "            ""Lock a choice, then face the reveal together.""," \n "            ""A quick two-player contest with no hidden arithmetic.""" \n "        ]," \n "        2," \n "        2," \n "        [" \n "            ""Playable: simultaneous hidden choices and a reveal countdown.""," \n "            ""First to two round wins takes the best-of-three match; draws replay.""" \n "        ]" \n "    ]," \n "    [" \n "        ""uno""," \n "        ""UNO""," \n "        [" \n "            ""Shed cards quickly with two to four players.""," \n "            ""Ideal for short, preventable arguments.""" \n "        ]," \n "        2," \n "        4," \n "        [" \n "            ""Playable: paged private hands, stacking and draw chains.""," \n "            ""Call UNO before one card remains, or risk a callout.""" \n "        ]" \n "    ]" \n "];" \n "" \n "PGS_CFG_TABLE_CLASSES = [" \n "    ""Land_CampingTable_F""," \n "    ""Land_CampingTable_small_F""," \n "    ""Land_CampingTable_small_white_F""," \n "    ""Land_TablePlastic_01_F""" \n "];" \n "PGS_CFG_SEAT_COUNT = 4;" \n "PGS_CFG_SEAT_OFFSETS = [" \n "    [0, -1.05, 0]," \n "    [0, 1.05, 0]," \n "    [-1.35, 0, 0]," \n "    [1.35, 0, 0]" \n "];" \n "PGS_CFG_SEAT_EXIT_OFFSETS = [" \n "    [0, -1.85, 0]," \n "    [0, 1.85, 0]," \n "    [-2.05, 0, 0]," \n "    [2.05, 0, 0]" \n "];" \n "PGS_CFG_SEAT_DIRECTIONS = [0, 180, 90, 270];" \n "PGS_CFG_SEATED_ANIMATION = ""HubSittingChairA_idle1"";" \n "PGS_CFG_ACTION_RANGE = 4.5;" \n "PGS_CFG_PERSONAL_ACTION_RANGE = 2;" \n "PGS_CFG_REQUEST_RANGE = 6;" \n "PGS_CFG_AUTHORITY_TICK = 0.5;" \n "PGS_CFG_CLIENT_TICK = 0.5;" \n "PGS_CFG_DISCOVERY_TICK = 10;" \n "PGS_CFG_MAINTENANCE_TICK = 10;" \n "PGS_CFG_CHECKERS_UI_TICK = 0.15;" \n "PGS_CFG_RPS_UI_TICK = 0.10;" \n "PGS_CFG_RPS_COUNTDOWN_SECONDS = 3;" \n "PGS_CFG_RPS_REVEAL_SECONDS = 3.5;" \n "PGS_CFG_SHOTGUN_UI_TICK = 0.10;" \n "PGS_CFG_SHOTGUN_STARTING_LIVES = 3;" \n "PGS_CFG_SHOTGUN_MAX_LIVES = 5;" \n "PGS_CFG_SHOTGUN_MIN_SHELLS = 2;" \n "PGS_CFG_SHOTGUN_MAX_SHELLS = 8;" \n "PGS_CFG_SHOTGUN_ITEMS_PER_LOAD = 2;" \n "PGS_CFG_SHOTGUN_INVENTORY_LIMIT = 4;" \n "PGS_CFG_SHOTGUN_REVEAL_SECONDS = 1.6;" \n "PGS_CFG_SHOTGUN_LOAD_REVEAL_SECONDS = 4.0;" \n "PGS_CFG_SHOTGUN_UI_SCALE = 1.18;" \n "PGS_CFG_SHOTGUN_UI_CENTER = [0.590, 0.5425];" \n "PGS_CFG_BLACKJACK_UI_
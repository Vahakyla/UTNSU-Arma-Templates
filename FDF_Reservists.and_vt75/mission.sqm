lved param [2, _actions]];" \n "    };" \n "    if (_phase in [""LOADING"", ""REVEAL""] && {(_table getVariable [""PGS_ShotgunPendingActorServer"", -1]) == _role}) then {" \n "        _table setVariable [""PGS_ShotgunPendingActorServer"", [_role, _alive] call PGS_fnc_shotgunGetNextAliveRole];" \n "    };" \n "    _state set [17, format [""%1 left the match and was eliminated."", _names param [_role, ""Player""]]];" \n "    [_table, _state] call PGS_fnc_shotgunSetSnapshotServer;" \n "};" \n "" \n "PGS_fnc_shotgunReconcilePlayersServer = {" \n "    params [[""_table"", objNull]];" \n "    if (!isServer || {isNull _table} || {!(_table getVariable [""PGS_ShotgunActive"", false])}) exitWith {};" \n "    private _players = _table getVariable [""PGS_ShotgunPlayers"", []];" \n "    private _seatIndices = _table getVariable [""PGS_ShotgunSeatIndices"", []];" \n "    private _seats = [(_table getVariable [""PGS_TableSeats"", []])] call PGS_fnc_normalizeSeats;" \n "    for ""_role"" from 0 to ((count _players) - 1) do {" \n "        private _unit = _players param [_role, objNull];" \n "        private _seat = _seatIndices param [_role, -1];" \n "        private _valid = !isNull _unit" \n "            && {_seat >= 0}" \n "            && {_seat < PGS_CFG_SEAT_COUNT}" \n "            && {(_seats param [_seat, objNull]) == _unit}" \n "            && {_unit in allPlayers}" \n "            && {alive _unit}" \n "            && {(lifeState _unit) != ""INCAPACITATED""}" \n "            && {(vehicle _unit) == _unit};" \n "        if (!_valid) then {" \n "            [_table, _unit, _seat] call PGS_fnc_shotgunHandleDepartureServer;" \n "        };" \n "    };" \n "}; " \n " " \n "PGS_fnc_blackjackCreateEmptySnapshot = {" \n "    params [" \n "        [""_count"", 0]," \n "        [""_stacksSource"", []]" \n "    ];" \n "    private _stacks = [];" \n "    private _numbers = [];" \n "    private _hands = [];" \n "    private _statuses = [];" \n "    private _actions = [];" \n "    private _booleans = [];" \n "    for ""_role"" from 0 to (_count - 1) do {" \n "        _stacks pushBack (_stacksSource param [_role, PGS_CFG_BLACKJACK_STARTING_CHIPS]);" \n "        _numbers pushBack 0;" \n "        _hands pushBack [];" \n "        _statuses pushBack ""BETTING"";" \n "        _actions pushBack ""Choose an even bet"";" \n "        _booleans pushBack false;" \n "    };" \n "    [" \n "        ""IDLE"", 0, -1, _stacks, +_numbers, _hands, +_numbers, _statuses," \n "        _actions, [], 0, false, false, ""Waiting for Blackjack."", +_numbers," \n "        _booleans, 0" \n "    ]" \n "};" \n "" \n "PGS_fnc_blackjackPublishRevisionServer = {" \n "    params [[""_table"", objNull]];" \n "    if (!isServer || {isNull _table}) exitWith {};" \n "    _table setVariable [" \n "        ""PGS_BlackjackRevision""," \n "        (_table getVariable [""PGS_BlackjackRevision"", 0]) + 1," \n "        true" \n "    ];" \n "    _table setVariable [" \n "        ""PGS_TableRevision""," \n "        (_table getVariable [""PGS_TableRevision"", 0]) + 1," \n "        true" \n "    ];" \n "};" \n "" \n "PGS_fnc_blackjackSetSnapshotServer = {" \n "    params [" \n "        [""_table"", objNull]," \n "        [""_snapshot"", []]" \n "    ];" \n "    if (!isServer || {isNull _table} || {(typeName _snapshot) != ""ARRAY""}) exitWith {};" \n "    _table setVariable [""PGS_BlackjackSnapshotServer"", _snapshot];" \n "    _table setVariable [""PGS_BlackjackSnapshot"", _snapshot, true];" \n "    [_table] call PGS_fnc_blackjackPublishRevisionServer;" \n "};" \n "" \n "PGS_fnc_blackjackClearServer = {" \n "    params [[""_table"", objNull]];" \n "    if (!isServer || {isNull _table}) exitWith {};" \n "    _table setVariable [""PGS_BlackjackActive"", false, true];" \n "    _table setVariable [""PGS_BlackjackFinished"", false, true];" \n "    _table setVariable [""PGS_BlackjackGameId"", """", true];" \n "    _table setVariable [""PGS_BlackjackPlayers"", [], true];" \n "    _table setVariable [""PGS_
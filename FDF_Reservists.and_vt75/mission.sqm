tions pushBack ""No playable chips"";" \n "            };" \n "        };" \n "    };" \n "    if (_eligible <= 0) exitWith {" \n "        _state set [0, ""SESSION_END""];" \n "        _state set [2, -1];" \n "        _state set [7, _statuses];" \n "        _state set [8, _actions];" \n "        _state set [13, ""No seated player has enough chips for the minimum bet. The dealer wins the session.""];" \n "        _state set [15, _nextReady];" \n "        _table setVariable [""PGS_BlackjackFinished"", true, true];" \n "        _table setVariable [""PGS_TablePhase"", ""FINISHED"", true];" \n "        [_table, _state] call PGS_fnc_blackjackSetSnapshotServer;" \n "        false" \n "    };" \n "    private _round = _state param [1, 0];" \n "    if (_incrementRound) then {_round = _round + 1;};" \n "    _state set [0, ""BETTING""];" \n "    _state set [1, _round];" \n "    _state set [2, -1];" \n "    _state set [4, _bets];" \n "    _state set [5, _hands];" \n "    _state set [6, _totals];" \n "    _state set [7, _statuses];" \n "    _state set [8, _actions];" \n "    _state set [9, []];" \n "    _state set [10, 0];" \n "    _state set [11, false];" \n "    _state set [12, false];" \n "    _state set [13, format [""Round %1: every active player must place an even bet."", _round]];" \n "    _state set [14, _results];" \n "    _state set [15, _nextReady];" \n "    _state set [16, count (_table getVariable [""PGS_BlackjackShoeServer"", []])];" \n "    _table setVariable [""PGS_BlackjackDealerHandServer"", []];" \n "    _table setVariable [""PGS_BlackjackDealerNextAt"", 0, true];" \n "    _table setVariable [""PGS_BlackjackEpoch"", (_table getVariable [""PGS_BlackjackEpoch"", 0]) + 1, true];" \n "    [_table, _state] call PGS_fnc_blackjackSetSnapshotServer;" \n "    true" \n "};" \n "" \n "PGS_fnc_blackjackStartServer = {" \n "    params [[""_table"", objNull]];" \n "    if (!isServer || {isNull _table}) exitWith {false};" \n "    if ([_table] call PGS_fnc_isTableGameActive) exitWith {false};" \n "    if ((_table getVariable [""PGS_TableSelectedGame"", """"]) != ""blackjack"") exitWith {false};" \n "    if ((_table getVariable [""PGS_TablePhase"", ""LOBBY""]) != ""READY"") exitWith {false};" \n "    private _seats = [(_table getVariable [""PGS_TableSeats"", []])] call PGS_fnc_normalizeSeats;" \n "    private _players = [];" \n "    private _names = [];" \n "    private _seatIndices = [];" \n "    for ""_seat"" from 0 to (PGS_CFG_SEAT_COUNT - 1) do {" \n "        private _unit = _seats param [_seat, objNull];" \n "        if (!isNull _unit) then {" \n "            _players pushBack _unit;" \n "            _names pushBack (name _unit);" \n "            _seatIndices pushBack _seat;" \n "        };" \n "    };" \n "    private _count = count _players;" \n "    if (_count < 1 || {_count > 4}) exitWith {false};" \n "    private _stacks = [];" \n "    for ""_role"" from 0 to (_count - 1) do {" \n "        _stacks pushBack PGS_CFG_BLACKJACK_STARTING_CHIPS;" \n "    };" \n "    private _state = [_count, _stacks] call PGS_fnc_blackjackCreateEmptySnapshot;" \n "    _state set [0, ""BETTING""];" \n "    _state set [1, 1];" \n "    _state set [13, ""Round 1: every active player must place an even bet.""];" \n "    private _shoe = call PGS_fnc_blackjackCreateShoeServer;" \n "    _state set [16, count _shoe];" \n "    _table setVariable [""PGS_BlackjackActive"", true, true];" \n "    _table setVariable [""PGS_BlackjackFinished"", false, true];" \n "    _table setVariable [" \n "        ""PGS_BlackjackGameId""," \n "        format [""PGS_BLACKJACK_%1_%2"", floor (serverTime * 10), floor (random 1000000)]," \n "        true" \n "    ];" \n "    _table setVariable [""PGS_BlackjackPlayers"", _players, true];" \n "    _table setVariable [""PGS_BlackjackPlayerNames"", _names, true];" \n "    _table setVariable [""PGS_BlackjackSeatIndices"", _seatIndices, true];" \n "    _table setVariable [""PGS_BlackjackEpoch"", 1, true];" \n "    _table setVariable [""PGS
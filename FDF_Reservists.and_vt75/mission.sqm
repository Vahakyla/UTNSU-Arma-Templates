1));" \n "    private _liveCount = 1 + floor (random (_shellCount - 1));" \n "    private _blankCount = _shellCount - _liveCount;" \n "    private _source = [];" \n "    for ""_index"" from 1 to _liveCount do {_source pushBack 1;};" \n "    for ""_index"" from 1 to _blankCount do {_source pushBack 0;};" \n "    private _chamber = [];" \n "    while {(count _source) > 0} do {" \n "        private _pick = floor (random (count _source));" \n "        _chamber pushBack (_source deleteAt _pick);" \n "    };" \n "    private _itemCatalog = [""BLADE"", ""BEER"", ""CIGAR"", ""SPYGLASS"", ""CUFFS"", ""INVERTER""];" \n "    private _oldInventories = _state param [5, []];" \n "    private _inventories = [];" \n "    private _actions = +(_state param [15, []]);" \n "    for ""_role"" from 0 to ((count _alive) - 1) do {" \n "        private _inventory = +(_oldInventories param [_role, []]);" \n "        if (_alive param [_role, false]) then {" \n "            private _slots = (PGS_CFG_SHOTGUN_INVENTORY_LIMIT - (count _inventory)) max 0;" \n "            private _dealCount = PGS_CFG_SHOTGUN_ITEMS_PER_LOAD min _slots;" \n "            if (_dealCount > 0) then {" \n "                for ""_deal"" from 1 to _dealCount do {" \n "                    _inventory pushBack (_itemCatalog param [floor (random (count _itemCatalog)), ""BEER""]);" \n "                };" \n "            };" \n "            _actions set [_role, format [""Load %1 ready - %2 item%3 carried"", (_state param [1, 0]) + 1, count _inventory, if ((count _inventory) == 1) then {""""} else {""s""}]];" \n "        };" \n "        _inventories pushBack _inventory;" \n "    };" \n "    private _load = (_state param [1, 0]) + 1;" \n "    private _version = (_state param [18, 0]) + 1;" \n "    _state set [0, ""LOADING""];" \n "    _state set [1, _load];" \n "    _state set [2, -1];" \n "    _state set [5, _inventories];" \n "    _state set [8, _liveCount];" \n "    _state set [9, _blankCount];" \n "    _state set [10, _shellCount];" \n "    _state set [11, true];" \n "    _state set [12, -1];" \n "    _state set [13, -1];" \n "    _state set [14, -1];" \n "    _state set [15, _actions];" \n "    _state set [17, format [""Load %1: memorize %2 LIVE and %3 BLANK shell%4. The colour ledger will now be hidden."", _load, _liveCount, _blankCount, if (_blankCount == 1) then {""""} else {""s""}]];" \n "    _state set [18, _version];" \n "    _state set [19, serverTime + PGS_CFG_SHOTGUN_LOAD_REVEAL_SECONDS];" \n "    _table setVariable [""PGS_ShotgunChamberServer"", _chamber];" \n "    _table setVariable [""PGS_ShotgunPendingActorServer"", _actor];" \n "    _table setVariable [""PGS_ShotgunPendingReloadServer"", false];" \n "    [_table] call PGS_fnc_shotgunClearPrivatePeeksServer;" \n "    [_table, _state] call PGS_fnc_shotgunSetSnapshotServer;" \n "    true" \n "};" \n "" \n "PGS_fnc_shotgunStartServer = {" \n "    params [[""_table"", objNull]];" \n "    if (!isServer || {isNull _table}) exitWith {false};" \n "    if ([_table] call PGS_fnc_isTableGameActive) exitWith {false};" \n "    if ((_table getVariable [""PGS_TableSelectedGame"", """"]) != ""shotgun"") exitWith {false};" \n "    if ((_table getVariable [""PGS_TablePhase"", ""LOBBY""]) != ""READY"") exitWith {false};" \n "    private _seats = [(_table getVariable [""PGS_TableSeats"", []])] call PGS_fnc_normalizeSeats;" \n "    private _players = [];" \n "    private _names = [];" \n "    private _seatIndices = [];" \n "    for ""_seat"" from 0 to (PGS_CFG_SEAT_COUNT - 1) do {" \n "        private _unit = _seats param [_seat, objNull];" \n "        if (!isNull _unit) then {" \n "            _players pushBack _unit;" \n "            _names pushBack (name _unit);" \n "            _seatIndices pushBack _seat;" \n "        };" \n "    };" \n "    private _count = count _players;" \n "    if (_count < 2 || {_count > 4}) exitWith {false};" \n "    private _state = [_count] call PGS_fnc_shotgunCreateEmptySnapshot;" \n "    private _firstActor = floor (random _count);" \n "    _table setVariable [""PGS_ShotgunActive"", true, true];" \n "    _table setVariable [""PGS_ShotgunFinished"", false, true];" \n "    _table setVariable [" \n "        ""PGS_ShotgunGameId""," \n "        format [""PGS_SHOTGUN_%1_%2"", floor (serverTime * 10), floor (random 1000000)]," \n "        true" \n "    ];" \n "    _table setVariable [""PGS_ShotgunPlayers"", _players, true];" \n "    _table setVariable [""PGS_ShotgunPlayerNames"", _names, true];" \n "    _table setVariable [""PGS_ShotgunSeatIndices"", _seatIndices, true];" \n "    _table setVariable [""PGS_ShotgunRevision"", 0, true];" \n "    _table setVariable [""PGS_ShotgunSnapshotServer"", _state];" \n "    _table setVariable [""PGS_TablePhase"", ""PLAYING"", true];" \n "    [_table, _state, _firstActor] call PGS_fnc_shotgunCreateLoadServer" \n "};" \n "" \n "PGS_fnc_shotgunFinishServer = {" \n "    params [" \n "        [""_table"", objNull]," \n "        [""_snapshot"", []]," \n "        [""_winner"", -1]," \n "        [""_message"", ""Shotgun Roulette is finished.""]" \n "    ];" \n "    if (!isServer || {isNull _table}) exitWith {};" \n "    private _state = +_snapshot;" \n "    _state set [0, ""FINISHED""];" \n "    _state set [2, -1];" \n "    _state set [16, _winner];" \n "    _state set [17, _message];" \n "    _state set [19, 0];" \n "    _table setVariable [""PGS_ShotgunFinished"", true, true];" \n "    _table setVariable [""PGS_TablePhase"", ""FINISHED"", true];" \n "    _table setVariable [""PGS_ShotgunPendingActorServer"", -1];" \n "    _table setVariable [""PGS_ShotgunPendingReloadServer"", false];" \n "    [_table, _state] call PGS_fnc_shotgunSetSnapshotServer;" \n "};" \n "" \n "PGS_fnc_shotgunProgressServer = {" \n "    params [[""_table"", objNull]];" \n "    if (!isServer || {isNull _table} || {!(_table getVariable [""PGS_ShotgunActive"", false])}) exitWith {};" \n "    private _state = +(_table getVariable [""PGS_ShotgunSnapshotServer"", []]);" \n "    private _phase = _state param [0, """"];" \n "    if (_phase == ""LOADING"") exitWith {" \n "        if (serverTime >= (_state param [19, 0])) then {" \n "            private _pendingActor = _table getVariable [""PGS_ShotgunPendingActorServer"", -1];" \n "            private _resolved = [_table, _state, _pendingActor] call PGS_fnc_shotgunResolveCuffsServer;" \n "            private _actor = _resolved param [0, -1];" \n "            private _names = _table getVariable [""PGS_ShotgunPlayerNames"", []];" \n "            _state set [0, ""PLAYING""];" \n "            _state set [2, _actor];" \n "            _state set [6, _resolved param [1, _state param [6, []]]];" \n "            _state set [8, -1];" \n "            _state set [9, -1];" \n "            _state set [15, _resolved param [2, _state param [15, []]]];" \n "            _state set [17, format [""The colour ledger is hidden. %1 holds the shotgun; track every reveal."", _names param [_actor, ""Player""]]];" \n "            _state set [19, 0];" \n "            _table setVariable [""PGS_ShotgunPendingActorServer"", -1];" \n "            [_table, _state] call PGS_fnc_shotgunSetSnapshotServer;" \n "        };" \n "    };" \n "    if (_phase != ""REVEAL"") exitWith {};" \n "    if (serverTime < (_state param [19, 0])) exitWith {};" \n "    private _alive = _state param [4, []];" \n "    private _living = {_x} count _alive;" \n "    if (_living <= 1) exitWith {" \n "        private _winner = [-1, _alive] call PGS_fnc_shotgunGetNextAliveRole;" \n "        private _names = _table getVariable [""PGS_ShotgunPlayerNames"", []];" \n "        [_table, _state, _winner, format [""%1 is the last player standing."", _names param [_winner, ""Player""]]] call PGS_fnc_shotgunFinishServer;" \n "    };" \n "    private _pendingActor = _table getVariable [""PGS_ShotgunPendingActorServer"", -1];" \n "    private _resolved = [_table, _state, _pendingActor] call PGS_fnc_shotgunResolveCuffsServer;" \n "    private _actor = _resolved param [0